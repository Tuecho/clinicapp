# Redis Configuration
REDIS_HOST=redis_clinic
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # Uncomment if Redis requires password

# Groq API Key (para el chatbot IA)
GROQ_API_KEY=tu_api_key_de_groq

# Gmail SMTP Password (para notificaciones por email)
# Usa una contraseña de aplicación de Google, no tu contraseña normal
SMTP_PASSWORD=tu_contraseña_de_aplicacion_gmail

# ============== SEGURIDAD Y PRIVACIDAD (RGPD) ==============

# Encriptación de datos personales (AES-256-GCM)
# 生成 clave: openssl rand -hex 32 (debe tener 64+ caracteres hex)
# ENCRYPTION_KEY=  # Opcional - se genera automáticamente si no existe

# Habilitar encriptación (1=activada, 0=desactivada)
ENCRYPTION_ENABLED=1